from pathlib import Path

VERSION = "0.1.0"

configfile: "config/config.yaml"
workdir: config["output_directory"]
basedir = Path(workflow.basedir)

TOOLS = config["tools"]
BENCHMARKS = config["benchmarks"]


def get_input(wildcards, results):
    return {
        "ribo": basedir.parent / config["data"][results]["ribo"],
        "rna": basedir.parent / config["data"][results]["rna"],
        "samples": basedir.parent / config["data"][results]["samples"],
    }

rule all:
    input:
        expand("{benchmark}/results/{tool}/results.txt", tool=TOOLS, benchmark=BENCHMARKS),
        expand("{benchmark}/results/{tool}/benchmark.txt", tool=TOOLS, benchmark=BENCHMARKS)

rule run_benchmark1:
    input:
        unpack(lambda wildcards: get_input(wildcards, results="benchmark1"))
    output:
        csv = "<results>/results/{tool}/results.txt",
        bench = "<results>/results/{tool}/benchmark.txt"
    log:
        "<results>/logs/{tool}.log"
    pathvars:
        results = "benchmark1"
    params:
        script_dir = basedir / "scripts",
        script = lambda wildcards: basedir / "scripts" / f"run_{wildcards.tool}.R"
    conda:
        lambda wildcards: str(basedir / "envs" / f"{wildcards.tool}.yaml")
    shell:
        """
        export SCRIPT_DIR={params.script_dir}
        export OMP_NUM_THREADS={threads}
        export OPENBLAS_NUM_THREADS={threads}
        export MKL_NUM_THREADS={threads}
        export BLAS_NUM_THREADS={threads}
        MEM_KB=$(( {resources.mem_mb} * 1024 ))
        ulimit -v $MEM_KB
        /usr/bin/time -v -o {output.bench} \
        Rscript --vanilla {params.script} \
            --ribo {input.ribo} \
            --rna {input.rna} \
            --samples {input.samples} \
            --out {output.csv} \
            &> {log}
        """

rule run_benchmark2:
    input:
        unpack(lambda wildcards: get_input(wildcards, results="benchmark2"))
    output:
        csv = "<results>/results/{tool}/results.txt",
        bench = "<results>/results/{tool}/benchmark.txt"
    log:
