from pathlib import Path

VERSION = "0.1.0"

configfile: "config/config.yaml"
workdir: config["output_directory"]
basedir = Path(workflow.basedir)

TOOLS_1= config["tools"]
TOOLS_2 = [t for t in TOOLS_1 if t not in config["params"]["benchmark2"]["exclude"]]
BENCHMARKS = config["benchmarks"]

N_PERM = config["params"]["benchmark2"]["n_permutations"]

def get_input(wildcards, results):
    return {
        "ribo": basedir.parent / config["data"][results]["ribo"],
        "rna": basedir.parent / config["data"][results]["rna"],
        "samples": basedir.parent / config["data"][results]["samples"],
    }

# rule all:
#     input:
#         expand("{benchmark}/results/{tool}/results.txt", tool=TOOLS_1, benchmark=BENCHMARKS),
#         expand("{benchmark}/results/{tool}/benchmark.txt", tool=TOOLS_1, benchmark=BENCHMARKS)

rule all:
    input:
        "benchmark1/evaluation/results.csv",
        "benchmark1/evaluation/stats.csv",
        "benchmark1/evaluation/classification_metrics.csv",
        multiext("benchmark1/evaluation/roc_curves", ".svg", ".png"),
        multiext("benchmark1/evaluation/auc_barplot", ".svg", ".png"),
        multiext("benchmark1/evaluation/confusion_matrices", ".svg", ".png"),
        multiext("benchmark1/evaluation/classification_metrics", ".svg", ".png"),
        "benchmark2/evaluation/results.csv",

rule run_benchmark1:
    input:
        unpack(lambda wildcards: get_input(wildcards, results="benchmark1"))
    output:
        csv = "<results>/results/{tool}/results.csv",
        bench = "<results>/results/{tool}/benchmark.txt"
    log:
        "<results>/logs/{tool}.log"
    pathvars:
        results = "benchmark1"
    params:
        fdr = config["params"]["benchmark1"]["fdr_threshold"],
        script_dir = basedir / "scripts",
        script = lambda wildcards: basedir / "scripts" / f"run_{wildcards.tool}.R"
    conda:
        lambda wildcards: str(basedir / "envs" / f"{wildcards.tool}.yaml")
    shell:
        """
        export SCRIPT_DIR={params.script_dir}
        export OMP_NUM_THREADS={threads}
        export OPENBLAS_NUM_THREADS={threads}
        export MKL_NUM_THREADS={threads}
        export BLAS_NUM_THREADS={threads}
        MEM_KB=$(( {resources.mem_mb} * 1024 ))
        ulimit -v $MEM_KB
        /usr/bin/time -v -o {output.bench} \
        Rscript --vanilla {params.script} \
            --ribo {input.ribo} \
            --rna {input.rna} \
            --samples {input.samples} \
            --out {output.csv} \
            --alpha {params.fdr} &> {log}
        """

rule evaluate_benchmark1:
    input:
        ref_genes = basedir.parent / config["data"]["benchmark1"]["rna"],
        gt_tran = basedir.parent / config["data"]["benchmark1"]["groundtruth"]["translation"],
        gt_abun = basedir.parent / config["data"]["benchmark1"]["groundtruth"]["abundance"],
        gt_buff = basedir.parent / config["data"]["benchmark1"]["groundtruth"]["buffering"],
        csvs = expand("<results>/results/{tool}/results.csv", tool=TOOLS_1)
    output:
        summary = "<results>/evaluation/results.csv",
        stats = "<results>/evaluation/stats.csv",
        cls_metrics = "<results>/evaluation/classification_metrics.csv",
        roc = multiext("<results>/evaluation/roc_curves", ".svg", ".png"),
        auc = multiext("<results>/evaluation/auc_barplot", ".svg", ".png"),
        mat = multiext("<results>/evaluation/confusion_matrices", ".svg", ".png"),
        cls = multiext("<results>/evaluation/classification_metrics", ".svg", ".png")
    log:
        "<results>/logs/evaluation.log"
    pathvars:
        results = "benchmark1"
    params:
        dir = subpath(output.summary, parent=True),
        script_dir = basedir / "scripts",
        script = basedir / "scripts" / "run_evaluation.R"
    conda:
        basedir / "envs" / "evaluation.yaml"
    shell:
        """
        export SCRIPT_DIR={params.script_dir}
        Rscript --vanilla {params.script} \
            --rna {input.ref_genes} \
            --translation {input.gt_tran} \
            --abundance {input.gt_abun} \
            --buffering {input.gt_buff} \
            --results {input.csvs} \
            --out {params.dir} &> {log}
        """

rule run_benchmark2:
    input:
        unpack(lambda wildcards: get_input(wildcards, results="benchmark2"))
    output:
        # these are deleted? we only need the final output...
        csv = expand("<results>/results/{tool}/results{n}.csv", n=range(N_PERM))
    log:
        "<results>/logs/{tool}.log"
    pathvars:
        results = "benchmark2"
    wildcard_constraints:
        tool="|".join(TOOLS_2)
    params:
        script_dir = basedir / "scripts",
        script = lambda wildcards: basedir / "scripts" / f"permute_{wildcards.tool}.R",
        n_perm = N_PERM
    conda:
        lambda wildcards: str(basedir / "envs" / f"{wildcards.tool}.yaml")
    shell:
        """
        export SCRIPT_DIR={params.script_dir}
        Rscript {params.script} \
            --ribo {input.ribo} \
            --rna {input.rna} \
            --samples {input.samples} \
            --out {output.csv} \
            &> {log}
        """
